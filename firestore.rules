rules_version = '2';
// ⚠️ 一時復旧用：元の「全許可」ルールに戻しています（ログイン等を即復旧するため）。
//    セキュリティは緩いままなので、後述の「段階移行」で1コレクションずつ安全化してください。
//    （前回の厳格版は user_deleting_scheduled 等を本人限定にしたためログイン時の読取が拒否され、
//     アプリが動かなくなりました。まずは復旧を最優先。）
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
